generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/project2"
}

datasource db {
  provider = "postgresql"
  url      = env("PROJECT2_DATABASE_URL")
}

model Task {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?
  isDone      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([isDone])
}
