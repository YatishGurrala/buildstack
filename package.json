{
  "name": "buildstack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate:core": "prisma generate --schema prisma/core/schema.prisma",
    "prisma:generate": "npm run prisma:generate:core",
    "prisma:migrate:core": "prisma migrate dev --schema prisma/core/schema.prisma",
    "prisma:migrate": "npm run prisma:migrate:core",
    "prisma:deploy:core": "prisma migrate deploy --schema prisma/core/schema.prisma",
    "prisma:deploy": "npm run prisma:deploy:core",
    "seed:core": "tsx scripts/seed-core.ts",
    "db:up": "docker compose up -d db",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@sentry/nextjs": "^10.49.0",
    "google-auth-library": "^10.5.0",
    "jose": "^6.1.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "pino": "^10.1.0",
    "prisma": "^6.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pino-pretty": "^13.1.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
